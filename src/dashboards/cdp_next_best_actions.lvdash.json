{
  "datasets": [
    {
      "name": "nba_kpis",
      "displayName": "NBA KPIs",
      "queryLines": [
        "SELECT ",
        "  COUNT(*) AS total_merchants_with_actions, ",
        "  COUNT(CASE WHEN urgency = 'immediate' THEN 1 END) AS immediate_actions, ",
        "  COUNT(CASE WHEN urgency = 'this_week' THEN 1 END) AS this_week_actions, ",
        "  ROUND(SUM(estimated_revenue_impact), 0) AS total_revenue_impact, ",
        "  ROUND(AVG(health_score), 1) AS avg_health_score, ",
        "  COUNT(CASE WHEN health_tier = 'critical' THEN 1 END) AS critical_merchants ",
        "FROM ahs_demos_catalog.cdp_360.gold_next_best_actions"
      ]
    },
    {
      "name": "nba_by_action",
      "displayName": "Merchants by Action Type",
      "queryLines": [
        "SELECT ",
        "  primary_action, ",
        "  COUNT(*) AS merchant_count, ",
        "  ROUND(SUM(estimated_revenue_impact), 0) AS revenue_impact, ",
        "  ROUND(AVG(health_score), 1) AS avg_health, ",
        "  COUNT(CASE WHEN urgency = 'immediate' THEN 1 END) AS immediate ",
        "FROM ahs_demos_catalog.cdp_360.gold_next_best_actions ",
        "GROUP BY primary_action ",
        "ORDER BY revenue_impact DESC"
      ]
    },
    {
      "name": "nba_by_urgency",
      "displayName": "Actions by Urgency",
      "queryLines": [
        "SELECT ",
        "  urgency, ",
        "  COUNT(*) AS merchant_count, ",
        "  ROUND(SUM(estimated_revenue_impact), 0) AS revenue_impact ",
        "FROM ahs_demos_catalog.cdp_360.gold_next_best_actions ",
        "GROUP BY urgency ",
        "ORDER BY CASE urgency ",
        "  WHEN 'immediate' THEN 1 ",
        "  WHEN 'this_week' THEN 2 ",
        "  WHEN 'this_month' THEN 3 ",
        "  ELSE 4 END"
      ]
    },
    {
      "name": "nba_by_channel",
      "displayName": "Actions by Channel",
      "queryLines": [
        "SELECT ",
        "  primary_channel, ",
        "  COUNT(*) AS merchant_count, ",
        "  ROUND(SUM(estimated_revenue_impact), 0) AS revenue_impact ",
        "FROM ahs_demos_catalog.cdp_360.gold_next_best_actions ",
        "GROUP BY primary_channel ",
        "ORDER BY revenue_impact DESC"
      ]
    },
    {
      "name": "nba_health_distribution",
      "displayName": "Health Score Distribution",
      "queryLines": [
        "SELECT ",
        "  health_tier, ",
        "  COUNT(*) AS merchant_count, ",
        "  ROUND(AVG(health_score), 1) AS avg_score, ",
        "  ROUND(SUM(txn_volume), 0) AS total_volume ",
        "FROM ahs_demos_catalog.cdp_360.gold_next_best_actions ",
        "GROUP BY health_tier ",
        "ORDER BY CASE health_tier ",
        "  WHEN 'critical' THEN 1 ",
        "  WHEN 'poor' THEN 2 ",
        "  WHEN 'fair' THEN 3 ",
        "  WHEN 'good' THEN 4 ",
        "  WHEN 'excellent' THEN 5 END"
      ]
    },
    {
      "name": "nba_top_immediate",
      "displayName": "Top Immediate Actions",
      "queryLines": [
        "SELECT ",
        "  merchant_name, ",
        "  segment, ",
        "  health_score, ",
        "  health_tier, ",
        "  primary_action, ",
        "  primary_channel, ",
        "  ROUND(estimated_revenue_impact, 0) AS revenue_impact, ",
        "  days_since_last_txn, ",
        "  ticket_count ",
        "FROM ahs_demos_catalog.cdp_360.gold_next_best_actions ",
        "WHERE urgency = 'immediate' ",
        "ORDER BY priority_score DESC ",
        "LIMIT 25"
      ]
    },
    {
      "name": "nba_segment_health",
      "displayName": "Segment Health Matrix",
      "queryLines": [
        "SELECT ",
        "  segment, ",
        "  ROUND(AVG(health_score), 1) AS avg_health, ",
        "  COUNT(*) AS merchants, ",
        "  COUNT(CASE WHEN health_tier IN ('critical', 'poor') THEN 1 END) AS unhealthy, ",
        "  ROUND(SUM(estimated_revenue_impact), 0) AS total_impact, ",
        "  FIRST(primary_action) AS most_common_action ",
        "FROM ahs_demos_catalog.cdp_360.gold_next_best_actions ",
        "GROUP BY segment ",
        "ORDER BY avg_health ASC"
      ]
    },
    {
      "name": "nba_revenue_impact_by_segment",
      "displayName": "Revenue at Risk by Segment",
      "queryLines": [
        "SELECT ",
        "  segment, ",
        "  ROUND(SUM(estimated_revenue_impact), 0) AS revenue_impact ",
        "FROM ahs_demos_catalog.cdp_360.gold_next_best_actions ",
        "GROUP BY segment ",
        "ORDER BY revenue_impact DESC"
      ]
    }
  ],
