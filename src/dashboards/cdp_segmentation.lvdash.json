{
  "datasets": [
    {
      "name": "seg_overview",
      "displayName": "Segment Overview",
      "queryLines": [
        "SELECT ",
        "  COALESCE(s.segment, 'unassigned') AS segment, ",
        "  COUNT(DISTINCT c.golden_id) AS merchant_count, ",
        "  COALESCE(SUM(e.txn_volume), 0) AS total_volume, ",
        "  COALESCE(ROUND(AVG(e.txn_volume), 2), 0) AS avg_volume, ",
        "  COALESCE(ROUND(AVG(e.txn_count), 1), 0) AS avg_txn_count, ",
        "  COALESCE(ROUND(AVG(e.days_since_last_txn), 0), 0) AS avg_recency, ",
        "  COALESCE(ROUND(AVG(e.ticket_count), 1), 0) AS avg_tickets ",
        "FROM main.cdp.gold_customer_360 c ",
        "LEFT JOIN main.cdp.gold_engagement_metrics e ON c.golden_id = e.golden_id ",
        "LEFT JOIN main.cdp.gold_segments s ON c.golden_id = s.golden_id ",
        "GROUP BY COALESCE(s.segment, 'unassigned') ",
        "ORDER BY total_volume DESC"
      ]
    },
    {
      "name": "seg_rfm_scores",
      "displayName": "RFM Score Distribution",
      "queryLines": [
        "SELECT ",
        "  COALESCE(s.segment, 'unassigned') AS segment, ",
        "  ROUND(AVG(s.r_score), 2) AS avg_r_score, ",
        "  ROUND(AVG(s.f_score), 2) AS avg_f_score, ",
        "  ROUND(AVG(s.m_score), 2) AS avg_m_score, ",
        "  COUNT(DISTINCT s.golden_id) AS merchant_count ",
        "FROM main.cdp.gold_segments s ",
        "GROUP BY COALESCE(s.segment, 'unassigned') ",
        "ORDER BY merchant_count DESC"
      ]
    },
    {
      "name": "seg_volume_share",
      "displayName": "Volume Share by Segment",
      "queryLines": [
        "SELECT ",
        "  COALESCE(s.segment, 'unassigned') AS segment, ",
        "  COALESCE(SUM(e.txn_volume), 0) AS segment_volume ",
        "FROM main.cdp.gold_customer_360 c ",
        "LEFT JOIN main.cdp.gold_engagement_metrics e ON c.golden_id = e.golden_id ",
        "LEFT JOIN main.cdp.gold_segments s ON c.golden_id = s.golden_id ",
        "GROUP BY COALESCE(s.segment, 'unassigned') ",
        "ORDER BY segment_volume DESC"
      ]
    },
    {
      "name": "seg_detail",
      "displayName": "Segment Detail",
      "queryLines": [
        "SELECT ",
        "  c.golden_id, ",
        "  COALESCE(c.first_name, '') AS merchant_name, ",
        "  COALESCE(s.segment, 'unassigned') AS segment, ",
        "  COALESCE(s.r_score, 0) AS r_score, ",
        "  COALESCE(s.f_score, 0) AS f_score, ",
        "  COALESCE(s.m_score, 0) AS m_score, ",
        "  COALESCE(e.txn_volume, 0) AS txn_volume, ",
        "  COALESCE(e.txn_count, 0) AS txn_count, ",
        "  COALESCE(e.days_since_last_txn, -1) AS days_since_last_txn ",
        "FROM main.cdp.gold_customer_360 c ",
        "LEFT JOIN main.cdp.gold_engagement_metrics e ON c.golden_id = e.golden_id ",
        "LEFT JOIN main.cdp.gold_segments s ON c.golden_id = s.golden_id ",
        "ORDER BY e.txn_volume DESC NULLS LAST ",
        "LIMIT 100"
      ]
    }
  ],
